      <aliases enabled='yes' />
      <column caption='Attack Source' datatype='string' name='[Attack_Source]' role='dimension' type='nominal' />
      <column caption='Year Date' datatype='date' name='[Calculation_0818628867244032]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='MAKEDATE(INT([Year]), 1, 1)' />
      </column>
      <column caption='Incidents 2015' datatype='integer' name='[Calculation_0818628893052929]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Calculation_0818628867244032]) = 2015&#13;&#10;THEN [Number_of_Incidents]&#13;&#10;END' />
      </column>
      <column caption='Incidents 2024' datatype='integer' name='[Calculation_0818628893614082]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF Year([Calculation_0818628867244032]) = 2024&#13;&#10;THEN [Number_of_Incidents]&#13;&#10;END' />
      </column>
      <column caption='Growth %' datatype='real' name='[Calculation_0818628896665603]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM([Calculation_0818628893614082])&#13;&#10;-&#13;&#10;SUM([Calculation_0818628893052929])&#13;&#10;)&#13;&#10;/&#13;&#10;SUM([Calculation_0818628893052929])' />
      </column>
      <column caption='Total Incidents' datatype='integer' name='[Calculation_1151780622897152]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Number_of_Incidents])' />
      </column>
      <column caption='Total Financial Loss (USD)' datatype='integer' name='[Calculation_1151780624338945]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Financial_Loss_USD])' />
      </column>
      <column caption='Most Common Threat Type' datatype='integer' name='[Calculation_1151780625551362]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Threat_Type])' />
      </column>
      <column caption='Highest Loss Country' datatype='integer' name='[Calculation_1151780626092035]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Country] : SUM([Financial_Loss_USD]) }' />
      </column>
      <column caption='Average Loss per Incident' datatype='real' name='[Calculation_1151780629385220]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Financial_Loss_USD]) / SUM([Number_of_Incidents])' />
      </column>
      <column caption='Loss Category' datatype='string' name='[Calculation_1151780629630981]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Financial_Loss_USD] &gt; 10000000 THEN &quot;Very High&quot;&#13;&#10;ELSEIF [Financial_Loss_USD] &gt; 5000000 THEN &quot;High&quot;&#13;&#10;ELSEIF [Financial_Loss_USD] &gt; 1000000 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;Low&quot;&#13;&#10;END' />
      </column>
